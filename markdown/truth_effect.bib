@article{smulders2010simplifying,
	title = {Simplifying jackknifing of {ERPs} and getting more out of it: {Retrieving} estimates of participants' latencies},
	volume = {47},
	copyright = {Copyright © 2009 Society for Psychophysiological Research},
	issn = {1469-8986},
	shorttitle = {Simplifying jackknifing of {ERPs} and getting more out of it},
	url = {https://onlinelibrary.wiley.com/doi/abs/10.1111/j.1469-8986.2009.00934.x},
	doi = {10.1111/j.1469-8986.2009.00934.x},
	abstract = {Research has demonstrated that the jackknifing procedure for estimating ERP latencies (J. Miller, T. Patterson, \& R. Ulrich, 1998) yields more accurate estimates of differences between experimental conditions in ERP latency than other methods. However, the scores resulting from this procedure require special adjustments for further analyses and do not directly reflect each participant's latency. Here, a simple transform is proposed that retrieves estimates of each participant's latency from the subaverage scores, rendering further adjustments superfluous. Other advantages of working with participants' latencies are discussed. Results of simulations support the validity of jackknifing and the retrieval transform.},
	language = {en},
	number = {2},
	urldate = {2023-10-12},
	journal = {Psychophysiology},
	author = {Smulders, Fren T. Y.},
	year = {2010},
	note = {\_eprint: https://onlinelibrary.wiley.com/doi/pdf/10.1111/j.1469-8986.2009.00934.x},
	keywords = {ERP latency, Event-related brain potential, Jackknifing, LRP, N2pc},
	pages = {387--392},
	file = {Full Text PDF:C\:\\Users\\Sven\\Zotero\\storage\\45XLER3B\\Smulders - 2010 - Simplifying jackknifing of ERPs and getting more o.pdf:application/pdf;Snapshot:C\:\\Users\\Sven\\Zotero\\storage\\4RRY26Y3\\j.1469-8986.2009.00934.html:text/html},
}

