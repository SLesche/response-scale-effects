	keywords = {Intelligence, Individual Differences, Short Term Memory, Adolescent, Adult, Attention, Brain, Brain Mapping, Cognition, Cognitive Processing Speed, ERP latencies, event-related potentials, Evoked Potentials, Executive Function, Female, Humans, Individuality, intelligence, Male, Memory, Middle Aged, processing speed, Reaction Time, reaction times, Young Adult},
	pages = {1498--1512},
	file = {EBSCO Full Text:C\:\\Users\\Sven\\Zotero\\storage\\IVBPR4CY\\Schubert et al. - 2017 - Is general intelligence little more than the speed.pdf:application/pdf},
