	pages = {29--45},
	file = {Snapshot:C\:\\Users\\Sven\\Zotero\\storage\\FT53IKVX\\0b1bdeaa-a85e-4c8d-b43e-84ae1baf4a20.html:text/html;Submitted Version:C\:\\Users\\Sven\\Zotero\\storage\\HFARTZ7Q\\Geiser et al. - 2010 - Analyzing true change in longitudinal multitrait-m.pdf:application/pdf},
