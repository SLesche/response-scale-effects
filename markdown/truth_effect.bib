@article{jalbert2020,
	address = {Netherlands},
	title = {Only half of what i’ll tell you is true: {Expecting} to encounter falsehoods reduces illusory truth},
	volume = {9},
	issn = {2211-369X},
	shorttitle = {Only half of what i’ll tell you is true},
	doi = {10.1016/j.jarmac.2020.08.010},
	abstract = {Information is judged as more true when it has been seen or heard repeatedly than when it is new. This illusory truth effect has important consequences in the real world, where we are repeatedly exposed to information of unknown veracity. While false information in natural contexts rarely comes with a warning label, false information in truth effect experiments often does. Commonly used experimental procedures alert participants to potential falsehoods at exposure through instructional warnings. Three experiments show that the size of the truth effect is over twice as large when such warnings are avoided. The influence of pre-exposure warnings on the size of the truth effect persists even after a delay of three to six days. These findings demonstrate that common experimental procedures invite a systematic underestimation of illusory truth effects. They also highlight that simple warnings can curb the impact of repetition on judgments of truth. (PsycInfo Database Record (c) 2025 APA, all rights reserved)},
	number = {4},
	journal = {Journal of Applied Research in Memory and Cognition},
	publisher = {Elsevier Science},
	author = {Jalbert, Madeline and Schwarz, Norbert and Newman, Eryn},
	year = {2020},
	keywords = {Exposure, Judgment, Metacognition, Truth, Verbal Fluency, Warnings},
	pages = {602--613},
	file = {Full Text PDF:C\:\\Users\\Sven\\Zotero\\storage\\QCE7JMVU\\Jalbert et al. - 2020 - Only half of what i’ll tell you is true Expecting to encounter falsehoods reduces illusory truth.pdf:application/pdf},
}

@article{lacassagne2022,
	title = {Is {Earth} a perfect square? {Repetition} increases the perceived truth of highly implausible statements},
	volume = {223},
	issn = {0010-0277},
	shorttitle = {Is {Earth} a perfect square?},
	url = {https://www.sciencedirect.com/science/article/pii/S0010027722000403},
	doi = {10.1016/j.cognition.2022.105052},
	abstract = {A single exposure to statements is typically enough to increase their perceived truth. This Truth-by-Repetition (TBR) effect has long been assumed to occur only with statements whose truth value is unknown to participants. Contrary to this hypothesis, recent research has found that statements contradicting participants' prior knowledge (as established from a first sample of participants) show a TBR effect following their repetition (in a second, independent sample of participants). As for now, however, attempts at finding a TBR effect for blatantly false (i.e., highly implausible) statements have failed. Here, we reasoned that highly implausible statements such as Elephants run faster than cheetahs may show repetition effects, provided a sensitive truth measure is used and statements are repeated more than just once. In a preregistered experiment, participants judged on a 100-point scale the truth of highly implausible statements that were either new to them or had been presented five times before judgment. We observed an effect of repetition: repeated statements were judged more true than new ones, although all judgments were judged below the scale midpoint. Exploratory analyses additionally show that about half the participants showed no or even a reversed effect of repetition. The results provide the first empirical evidence that repetition can increase perceived truth even for highly implausible statements, although not equally so for all participants and not to the point of making the statements look true.},
	urldate = {2026-06-22},
	journal = {Cognition},
	author = {Lacassagne, Doris and Béna, Jérémy and Corneille, Olivier},
	month = jun,
	year = {2022},
	keywords = {Illusory truth, Low plausibility, Multiple exposures, Repetition, Truth effect},
	pages = {105052},
	file = {Full Text PDF:C\:\\Users\\Sven\\Zotero\\storage\\H3CRQ337\\Lacassagne et al. - 2022 - Is Earth a perfect square Repetition increases the perceived truth of highly implausible statements.pdf:application/pdf;ScienceDirect Snapshot:C\:\\Users\\Sven\\Zotero\\storage\\72GM3D7T\\S0010027722000403.html:text/html},
}

@misc{murray2020,
	title = {"{I}'ve said it before and {I} will say it again": {Repeating} statements made by {Donald} {Trump} increases perceived truthfulness for individuals across the political spectrum},
	shorttitle = {"{I}'ve said it before and {I} will say it again"},
	url = {https://osf.io/preprints/psyarxiv/9evzc_v1/},
	doi = {10.31234/osf.io/9evzc},
	abstract = {Fact-checking organizations have reported that Donald Trump is prone to repeating patently false statements. Previous research has shown that repetition increases perceived truthfulness of even implausible statements (also known as the illusory truth effect). However, other research has shown that people may engage in motivated reasoning when interacting with someone from a different ideological group. We measured the effect of repeating statements made by Donald Trump on perceived truthfulness. Participants (N = 465) rated the truthfulness of different statements made by Donald Trump, some of which were repeated from an earlier phase of the experiment. Our results are striking. We observe an overall effect of repetition on perceived truthfulness that is equally robust regardless of political affiliation. Our results suggest that ideologically-motivated beliefs do not modulate the effect of repetition on perceived truthfulness of statements.},
	urldate = {2026-06-22},
	publisher = {PsyArXiv},
	author = {Murray, Samuel and Stanley, Matthew and McPhetres, Jonathon and Pennycook, Gordon and Seli, Paul},
	month = jan,
